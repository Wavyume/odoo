<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Базовий editable list (mrp.workorder); на Odoo 19 форма MO використовує primary mo_form нижче -->
    <record id="mrp_workorder_tree_editable_lavasta" model="ir.ui.view">
        <field name="name">mrp.workorder.tree.editable.lavasta</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_editable_view"/>
        <field name="arch" type="xml">
            <!-- Приховуємо стандартні стовпці кількості Odoo -->
            <xpath expr="//field[@name='qty_remaining']" position="attributes">
                <attribute name="column_invisible">True</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='qty_producing']" position="attributes">
                <attribute name="column_invisible">True</attribute>
            </xpath>
            <!-- Odoo 19: додатковий стовпець готової кількості -->
            <xpath expr="//field[@name='qty_ready']" position="attributes">
                <attribute name="column_invisible">True</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
            <!-- Замість них — сума lavasta_qty з Time Tracking -->
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="lavasta_total_qty" string="Кількість" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='duration_expected']" position="after">
                <field name="lavasta_individual_duration" optional="show"/>
                <field
                    name="lavasta_it_status"
                    widget="badge"
                    optional="show"
                    decoration-success="lavasta_it_status == 'confirmed'"
                    decoration-warning="lavasta_it_status == 'not_confirmed'"
                />
            </xpath>
        </field>
    </record>

    <!--
        Odoo 18+: форма замовлення на виробництво підставляє list_view_ref = mrp_production_workorder_tree_editable_view_mo_form,
        який знову виставляє column_invisible на qty_remaining / qty_ready — перевизначаємо після нього.
    -->
    <record id="mrp_workorder_tree_editable_mo_form_lavasta_qty" model="ir.ui.view">
        <field name="name">mrp.workorder.list.editable.mo.form.lavasta.qty</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_tree_editable_view_mo_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='qty_remaining']" position="attributes">
                <attribute name="column_invisible">True</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
            <xpath expr="//field[@name='qty_ready']" position="attributes">
                <attribute name="column_invisible">True</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
        </field>
    </record>
</odoo>
