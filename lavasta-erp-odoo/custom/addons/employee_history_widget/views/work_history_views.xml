<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_work_history_list" model="ir.ui.view">
        <field name="name">employee.work.history.list</field>
        <field name="model">employee.work.history</field>
        <field name="arch" type="xml">
            <list create="0"> 
                <field name="datetime"/>
                <field name="order"/>
                <field name="spec_op"/>
                <field name="fact_op"/>
                <field name="department_id"/>
                <field name="seconds"/>
                <field name="rate"/>
                <field name="qty"/>
                <field name="accrued"/>
            </list>
        </field>
    </record>

    <record id="view_employee_work_history_form" model="ir.ui.view">
        <field name="name">employee.work.history.form</field>
        <field name="model">employee.work.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" invisible="1"/>
                            <field name="datetime"/>
                            <field name="order"/>
                            <field name="department_id"/>
                            <field name="spec_op"/>
                            <field name="fact_op"/>
                        </group>
                        <group>
                            <field name="seconds"/>
                            <field name="rate"/>
                            <field name="qty"/>
                            <field name="accrued"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>